<% content_for :title, "Funds" %>

<div class="col-md-12">
	<div class="card">
		<div class="card-header">
			<div class="d-flex align-items-center">
				<div class="fw-bold">基金 · Funds</div>
				<a href="<%= new_fund_path %>" class="btn btn-primary btn-sm ms-auto"><i class="bi bi-plus"></i>新增</a>
			</div>
		</div>
		<div class="card-body">
			<div class="container-fluid">
				<div class="table-responsive">
					<table class="table table-hover" role="grid">
						<thead>
							<tr class="text-nowrap" role="row">
								<th>編號</th>
								<th>名称</th>
								<th>起投资金</th>
								<th>数量</th>
								<th>开始时间</th>
								<th>结束时间</th>
								<th>創建時間</th>
								<th>操作</th>
							</tr>
						</thead>
						<tbody>
							<% @funds.each do |fund| %>
								<tr>
									<td><%= fund.id %></td>
									<td><%= fund.name %></td>
									<td><%= fund.price %></td>
									<td><%= fund.quantity %></td>
									<td><%= fund.start_time %></td>
									<td><%= fund.end_time %></td>
									<td><%= fund.created_at.strftime("%Y.%m.%d %H:%M:%S") %></td>
									<td><a href="<%= fund_path(fund) %>"><i class="bi bi-eye-fill"></i></a></td>
								</tr>
							<% end %>
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
</div>
