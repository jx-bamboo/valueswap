<%
=begin%>
 <%= form_with(model: fund) do |form| %>
  <% if fund.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(fund.errors.count, "error") %> prohibited this fund from being saved:</h2>

      <ul>
        <% fund.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :price, style: "display: block" %>
    <%= form.text_field :price %>
  </div>

  <div>
    <%= form.label :description, style: "display: block" %>
    <%= form.textarea :description %>
  </div>

  <div>
    <%= form.label :user_id, style: "display: block" %>
    <%= form.text_field :user_id %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %> 
<%
=end%>


<div class="col-sm-12">
  <div class="card">

    <div class="card-header">
      <div class="fw-bold">添加基金 · Fund</div>
    </div>

    <%= form_with(model: fund) do |form| %>
      <% if fund.errors.any? %>
        <div style="color: red">
          <h2><%= pluralize(fund.errors.count, "error") %> prohibited this fund from being saved:</h2>

          <ul>
            <% fund.errors.each do |error| %>
            <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="card-body">
        <div class="row">

          <div class="col-sm-4">
            <div class="form-group mb-3">
              <%= form.label :name, "名称", class: "form-label" %>
              <%= form.text_field :name, class: "form-control" %>
            </div>
          </div>

          <div class="col-sm-2">
            <div class="form-group mb-3">
              <%= form.label :price, "起投资金", class: "form-label" %>
              <%= form.text_field :price, class: "form-control" %>
            </div>
          </div>

          <div class="col-sm-2">
            <div class="form-group mb-3">
              <%= form.label :quantity, "数量", class: "form-label" %>
              <%= form.text_field :quantity, class: "form-control" %>
            </div>
          </div>

          <div class="col-sm-2">
            <div class="form-group mb-3">
              <%= form.label :start_time, "开始时间", class: "form-label" %>
              <%= form.date_field :start_time, class: "form-control" %>
            </div>
          </div>

          <div class="col-sm-2">
            <div class="form-group mb-3">
              <%= form.label :end_time, "结束时间", class: "form-label" %>
              <%= form.date_field :end_time, class: "form-control" %>
            </div>
          </div>

          <div class="col-sm-6">
            <div class="form-group mb-3">
              <%= form.label :official_web, "官方网站", class: "form-label" %>
              <%= form.text_field :official_web, class: "form-control", placeholder: "https://www.binance.com" %>
            </div>
          </div>
          
          <div class="col-sm-6">
            <div class="form-group mb-3">
              <%= form.label :logo, "图标", class: "form-label" %>
              <%= form.file_field :logo, class: "form-control" %>
              <% if @fund.logo.present? %>
                <%= image_tag @fund.logo, class: "img-fluid" %>
              <% end %>
            </div>
          </div>

          <div class="col-sm-6">
            <div class="form-group mb-3">
              <%= form.label :description, "描述", class: "form-label" %>
              <%= form.text_area :description, class: "form-control" %>  
              <% if @fund.description.present? %>
                <%= @fund.description %>
              <% end %>
            </div>
          </div>

        </div>
      </div>

      <div class="card-action p-3">
        <%= form.submit "提交", class: "btn btn-success" %>
        <%= link_to "返回", funds_path, class: "btn btn-warning" %>
      </div>
    <% end %>
  </div>
</div>