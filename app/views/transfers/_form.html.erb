<%= form_with(model: transfer) do |form| %>
  <% if transfer.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(transfer.errors.count, "error") %> prohibited this transfer from being saved:</h2>

      <ul>
        <% transfer.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :transfer_type, style: "display: block" %>
    <%= form.number_field :transfer_type %>
  </div>

  <div>
    <%= form.label :txid, style: "display: block" %>
    <%= form.text_field :txid %>
  </div>

  <div>
    <%= form.label :coin, style: "display: block" %>
    <%= form.text_field :coin %>
  </div>

  <div>
    <%= form.label :amount, style: "display: block" %>
    <%= form.text_field :amount %>
  </div>

  <div>
    <%= form.label :network, style: "display: block" %>
    <%= form.text_field :network %>
  </div>

  <div>
    <%= form.label :address, style: "display: block" %>
    <%= form.text_field :address %>
  </div>

  <div>
    <%= form.label :user_id, style: "display: block" %>
    <%= form.text_field :user_id %>
  </div>

  <div>
    <%= form.label :address_id, style: "display: block" %>
    <%= form.text_field :address_id %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
