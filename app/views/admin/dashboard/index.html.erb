<div class="row">
	<div class="col-md-3">
	  <div class="card">
			<div class="text-center fs-1 p-3">
			  <i class="bi bi-ubuntu text-primary"></i>
			</div>
			<div class="p-3 fs-4 d-flex justify-content-between">
				<div class="">系統</div>
				<div class=""><%= @super_admin_count %></div>
			</div>
		</div>
	</div>

	<div class="col-md-3">
	  <div class="card">
			<div class="text-center fs-1 p-3">
			  <i class="bi bi-person-fill-gear text-info"></i>
			</div>
			<div class="p-3 fs-4 d-flex justify-content-between">
				<div class="">管理员</div>
				<div class=""><%= @admin_count %></div>
			</div>
		</div>
	</div>

	<div class="col-md-3">
	  <div class="card">
			<div class="text-center fs-1 p-3">
			  <i class="bi bi-person-fill-check text-success"></i>
			</div>
			<div class="p-3 fs-4 d-flex justify-content-between">
				<div class="">会员</div>
				<div class=""><%= @vip_count %></div>
			</div>
		</div>
	</div>

	<div class="col-md-3">
	  <div class="card">
			<div class="text-center fs-1 p-3">
			  <i class="bi bi-person-circle text-secondary"></i>
			</div>
			<div class="p-3 fs-4 d-flex justify-content-between">
				<div class="">用户</div>
				<div class=""><%= @user_count %></div>
			</div>
		</div>
	</div>
</div>
<hr/>
<div class="row">
	<div class="col-md-3">
    <div class="card">
			<div class="card-body">
				<div class="row">
					<div class="col-5">
						<div class="text-center">
							<i class="bi bi-currency-exchange text-warning fs-1"></i>
						</div>
					</div>
					<div class="col-7">
						<div>
							<p>交易所</p>
							<h4 class="card-title"><%= @exchange_count %></h4>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="col-md-3">
    <div class="card">
			<div class="card-body">
				<div class="row">
					<div class="col-5">
						<div class="text-center">
							<i class="bi bi-currency-dollar text-success fs-1"></i>
						</div>
					</div>
					<div class="col-7">
						<div>
							<p>交易资产</p>
							<h4 class="card-title"><%= @coin_count %></h4>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="col-md-3">
    <div class="card">
			<div class="card-body">
				<div class="row">
					<div class="col-5">
						<div class="text-center">
							<i class="bi bi-bank2 text-danger fs-1"></i>
						</div>
					</div>
					<div class="col-7">
						<div>
							<p>基金</p>
							<h4 class="card-title"><%= @fund_count %></h4>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="col-md-3">
    <div class="card">
			<div class="card-body">
				<div class="row">
					<div class="col-5">
						<div class="text-center">
							<i class="bi bi-airplane-engines-fill text-primary fs-1"></i>
						</div>
					</div>
					<div class="col-7">
						<div>
							<p>空頭</p>
							<h4 class="card-title"><%= @airdrop_count %></h4>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>