<%= turbo_frame_tag "asset-list" do %>
  <% if flash[:alert] %>
    <div class="alert alert-danger mb-3">
      <%= flash[:alert] %>
    </div>
  <% end %>
  <% if assets.empty? %>
    <p class="text-muted col-12">没有可用的资产，请尝试其他交易所。</p>
  <% else %>
    <% assets.each_with_index do |asset, index| %>
      <div class="card mb-2">
        <div class="card-body d-flex justify-content-between align-items-center p-2">
          <div>
            <h5 class="card-title mb-1"><%= asset.asset %></h5>
            <p class="card-text text-muted">余额: <%= asset.balance %> <%= asset.asset %></p>
          </div>
          <div>
            <button class="btn btn-success btn-sm me-2" data-bs-toggle="collapse" data-bs-target="#trade-form-<%= index %>" aria-expanded="false">交易</button>
          </div>
        </div>
        <div class="collapse mb-2 px-2" id="trade-form-<%= index %>">
          <div class="card card-body">
            <%= form_with model: Trade.new, url: trades_path, class: "row" do |form| %>
              <%= form.hidden_field :user_exchange_id, value: user_exchange.id %>
              <%#= form.hidden_field :coin_id, value: Coin.find_by(symbol: asset.asset)&.id %>
              <%= form.hidden_field :trade_type, value: "manual" %>
              <%= form.hidden_field :admin_id, value: current_user.id %>
              <%= form.hidden_field :order_id, value: SecureRandom.uuid %>
              <%= form.hidden_field :executed_at, value: Time.current %>

              <div class="mb-3 col-sm-3">
                <div class="input-group">
                  <label class="input-group-text fw-bold" for="side_<%= index %>">方向</label>
                  <%= form.select :side, options_for_select([["买入", "BUY"], ["卖出", "SELL"]], form.object.side), {}, class: "form-select", id: "side_#{index}", required: true %>
                </div>
              </div>

              <div class="mb-3 col-sm-3">
                <div class="input-group">
                  <label class="input-group-text fw-bold" for="order_type_<%= index %>">订单类型</label>
                  <%= form.select :order_type, options_for_select([["限价", "LIMIT"], ["市价", "MARKET"]], form.object.order_type), {}, class: "form-select", id: "order_type_#{index}", required: true %>
                </div>
              </div>

              <div class="mb-3 col-sm-3">
                <div class="input-group">
                  <span class="input-group-text fw-bold" id="price_<%= index %>">价格</span>
                  <%= form.text_field :price, class: "form-control", id: "price_#{index}", required: true, placeholder: "0.00" %>
                </div>
              </div>

              <div class="mb-3 col-sm-3">
                <div class="input-group">
                  <span class="input-group-text fw-bold" id="quantity_<%= index %>">数量</span>
                  <%= form.text_field :quantity, class: "form-control", id: "quantity_#{index}", required: true, placeholder: "0.00" %>
                </div>
              </div>

              <div class="text-end">
                <%= form.submit "提交", class: "btn btn-primary" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
<% end %>
