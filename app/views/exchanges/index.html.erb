<% content_for :title, "Exchanges" %>

<div class="col-md-12">
	<div class="card">
		<div class="card-header">
			<div class="d-flex align-items-center">
				<div class="fw-bold">交易所 · Exchanges</div>
				<a href="<%= new_exchange_path %>" class="btn btn-primary btn-sm ms-auto"><i class="bi bi-plus"></i>新增</a>
			</div>
		</div>
		<div class="card-body">
			<div class="container-fluid">
				<div class="table-responsive">
					<table class="table table-hover" role="grid">
						<thead>
							<tr class="text-nowrap" role="row">
								<th>編號</th>
								<th>Logo</th>
								<th>名稱</th>
								<th>网址</th>
								<th>备注信息</th>
								<th>創建時間</th>
								<th>操作</th>
							</tr>
						</thead>
						<tbody>
							<% @exchanges.each do |exchange| %>
								<tr>
									<td><%= exchange.id %></td>
									<td>
										<%#= image_tag exchange.logo, width: 32 %>
										<% if exchange.logo.attached? %>
											<%= image_tag exchange.logo, width: 32, class: "img-fluid" %>
										<% else %>
											<i class="bi bi-image text-muted" style="font-size: 32px;"></i>
										<% end %>
									</td>
									<td class="text-capitalize"><%= exchange.name %></td>
									<td><%= exchange.official_web %></td>
									<td><%= exchange.description %></td>
									<td><%= exchange.created_at.strftime("%Y.%m.%d %H:%M:%S") %></td>
									<td><a href="<%= exchange_path(exchange) %>"><i class="bi bi-eye-fill"></i></a></td>
								</tr>
							<% end %>
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
</div>