<% content_for :title, "Coins" %>

<div class="col-md-12">
	<div class="card">
		<div class="card-header">
			<div class="d-flex align-items-center">
				<div class="fw-bold">资产 · Coins</div>
				<a href="<%= new_coin_path %>" class="btn btn-primary btn-sm ms-auto"><i class="bi bi-plus"></i>新增</a>
			</div>
		</div>
		<div class="card-body">
			<div class="container-fluid">
				<div class="table-responsive">
					<table class="table table-hover" role="grid">
						<thead>
							<tr  class="text-nowrap" role="row">
								<th>編號</th>
								<th>Logo</th>
								<th>簡稱</th>
								<th>全稱</th>
								<th>報價貨幣</th>
								<th>創建時間</th>
								<th>操作</th>
							</tr>
						</thead>
						<tbody>
							<% @coins.each do |coin| %>
								<tr>
									<td><%= coin.id %></td>
									<td>
										<% if coin.logo.attached? %>
											<%= image_tag coin.logo, width: 32, class: "img-fluid" %>
										<% else %>
											<i class="bi bi-image text-muted" style="font-size: 32px;"></i>
										<% end %>
									</td>
									<td><%= coin.symbol %></td>
									<td><%= coin.name %></td>
									<td><%= coin.quote_coin %></td>
									<td><%= coin.created_at.strftime("%Y.%m.%d %H:%M:%S") %></td>
									<td>
										<a href="<%= coin_path(coin) %>"><i class="bi bi-eye-fill"></i></a>
									</td>
								</tr>
							<% end %>
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
</div>