<%= turbo_frame_tag "ex_form" do %>
  <div class="mt-3 mx-auto mx-sm-0 xs-count-down py-3 border border-secondary">
    <div class="px-3">

      <%= form_with model: @user_exchange, url: "/profile/create_user_exchange", method: "post" do |form| %>
        <div class="row">
          <div class="col-sm-4">
            <div class="form-group">
              <%= form.label :exchange, "交易所", class: "" %>
              <%= form.collection_select :exchange_id, 
                    Exchange.all, 
                    :id, 
                    :name, 
                    { prompt: "请选择一个交易所" }, 
                    { class: "form-control opacity-50", id: "user_exchange_exchange_id" } %>
            </div>
          </div>

          <div class="col-sm-8">
            <div class="form-group">
              <%= form.label :api_key, "API Key", class: "" %>
              <%= form.text_field :api_key, class: "form-control opacity-50" %>
              <small id="user_exchange_api_key" class="form-text text-secondary">我们永远不会与任何人分享您的API Key。</small>
            </div>

            <div class="form-group">
              <%= form.label :api_secret, "API Secret", class: "" %>
              <%= form.text_field :api_secret, class: "form-control opacity-50" %>
              <small id="emailHelp2" class="form-text text-secondary">我们永远不会与任何人分享您的API Secret。</small>
            </div>

            <div class="form-group">
              <%= form.label :memo, "备注" %>
              <%= form.text_field :memo, class: "form-control opacity-50" %>
            </div>
            <div class="form-group mt-3">
              <%= form.submit "提交", class: "btn-primary btn-sm px-3 text-light border-0 rounded" %>
              <%= link_to '取消', profile_index_path, class: "text-bg-warning btn-sm px-2 py-1 rounded" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>