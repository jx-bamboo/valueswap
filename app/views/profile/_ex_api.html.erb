<%= turbo_frame_tag "ex_api" do %>
  <% if exchanges_api.present? %>
    <table class="row">
      <thead>
        <tr class="row row-cols-4 text-nowrap">
          <th class="col">名称</th>
          <th class="col text-truncate">API Key</th>
          <th class="col">API Secret</th>
          <th class="col">备注</th>
        </tr>
      </thead>
      <tbody>
        <% exchanges_api.each do |ea| %>
          <tr class="row row-cols-4 text-light">
            <td><%= ea.exchange.name %></td>
            <td class="text-truncate"><%= mask_string ea.api_key %></td>
            <td class="text-truncate"><%= mask_string ea.api_secret %></td>
            <td><%= ea.memo %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
  <div class="mt-3">
    <%= link_to "添加 API", ex_form_profile_index_path, class: "btn-sm btn-primary text-light px-2 py-1 rounded", data: {"turbo-frame": "ex_form"} %>
  </div>
  
  <%= turbo_frame_tag "ex_form" %>
<% end %>