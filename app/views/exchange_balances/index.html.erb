<% content_for :title, "Exchange balances" %>

<div class="col-md-12 mt-3">
  <div class="card">
    <div class="card-header">
      <div class="d-flex align-items-center">
        <div class="fw-bold">资产快照</div>
        <a href="<%= new_exchange_balance_path %>" data-turbo="false" class="btn btn-primary btn-sm ms-auto"><i class="bi bi-plus"></i>新增</a>
      </div>
    </div>
    <div class="card-body">
      <div id="add-row_wrapper" class="dataTables_wrapper container-fluid dt-bootstrap4">
        <div class="row">
          <div class="table-responsive">
            <table class="table table-hover" role="grid">
              <thead>
                <tr class="text-nowrap">
                  <th>编号</th>
                  <th>用户</th>
                  <th>交易所</th>
                  <th>现货</th>
                  <th>资金</th>
                  <th>合约</th>
                  <th>創建時間</th>
                  <th>操作</th>
                </tr>
              </thead>
              <tbody>
                <% @exchange_balances.each do |exchange_balance| %>
                  <tr>
                    <td><%= exchange_balance.id %></td>
                    <td><%= exchange_balance.user.email %></td>
                    <td class="text-capitalize"><%= exchange_balance.user_exchange.exchange.name %></td>
                    <td><%= exchange_balance.spot %></td>
                    <td><%= exchange_balance.funding %></td>
                    <td><%= exchange_balance.usd_futures %></td>
                    <td><%= exchange_balance.created_at.strftime("%Y.%m.%d %H:%M:%S") %></td>
                    <td><a href="<%= exchange_balance_path(exchange_balance) %>"><i class="bi bi-eye-fill"></i></a></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
