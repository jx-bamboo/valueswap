<div class="col-md-12">
	<div class="card card-pricing">
		<div class="card-body">
			<div class="p-3">
				<div class="d-flex justify-content-between mb-3">
					<span>編號</span>
					<span><%= @exchange_balance.id %></span>
				</div>
				<div class="d-flex justify-content-between mb-3">
					<span>用户</span>
					<span><%= @exchange_balance.user.email %></span>
				</div>
				<div class="d-flex justify-content-between mb-3">
					<span>交易所</span>
					<span><%= @exchange_balance.user_exchange.exchange.name %></span>
				</div>
				<div class="d-flex justify-content-between mb-3">
					<span>现货</span>
					<span><%= @exchange_balance.spot %></span>
				</div>
				<div class="d-flex justify-content-between mb-3">
					<span>资金</span>
					<span><%= @exchange_balance.funding %></span>
				</div>
        <div class="d-flex justify-content-between mb-3">
					<span>合约</span>
					<span><%= @exchange_balance.usd_futures %></span>
				</div>
				<div class="card shadow-sm mb-3">
					<div class="card-header">
						<h5 class="card-title mb-0">原始数据</h5>
					</div>
					<div class="card-body">
						<% if @exchange_balance.ex_json.present? && @exchange_balance.ex_json.is_a?(Array) %>
							<table class="table table-striped table-hover">
								<thead>
									<tr>
										<th>钱包类型</th>
										<th>余额 (USDT)</th>
										<th>激活状态</th>
									</tr>
								</thead>
								<tbody>
									<% @exchange_balance.ex_json.each do |wallet| %>
										<% next if wallet["balance"].to_f.zero? && wallet["activate"] == false %> <%# 可选：跳过余额为0且未激活的钱包 %>
										<tr>
											<td><%= wallet["walletName"] %></td>
											<td><%= number_with_precision(wallet["balance"].to_f, precision: 8) %></td>
											<td>
												<span class="badge <%= wallet['activate'] ? 'bg-success' : 'bg-secondary' %>">
													<%= wallet["activate"] ? "已激活" : "未激活" %>
												</span>
											</td>
										</tr>
									<% end %>
								</tbody>
							</table>
						<% else %>
							<p class="text-muted">无原始数据</p>
						<% end %>
					</div>
				</div>
				<div class="d-flex justify-content-between mb-3">
					<span>創建時間</span>
					<span><%= @exchange_balance.created_at %></span>
				</div>
			</div>
		</div>
		<div class="nav p-3">
		  <%#= link_to "編輯", edit_exchange_balance_path(@exchange_balance), class: "btn btn-warning" %>&nbsp;
		  <%= link_to "返回", exchange_balances_path, class: "btn btn-primary" %>&nbsp;
		  <%= button_to "刪除", @exchange_balance, method: :delete, class: "btn btn-danger", data: { turbo_method: :delete, turbo_confirm: "確認刪除？" } %>
		</div>
	</div>
</div>