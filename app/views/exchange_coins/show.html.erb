<div class="col-sm-12">
	<div class="card card-pricing">
		<div class="card-body">
			<div class="p-3">
				<div class="d-flex justify-content-between mb-3">
					<span>編號</span>
					<span><%= @exchange_coin.id %></span>
				</div>
				<div class="d-flex justify-content-between mb-3">
					<span>交易所</span>
					<span><%= @exchange_coin.exchange.name %></span>
				</div>
        <div class="d-flex justify-content-between mb-3">
					<span>币种</span>
					<span><%= @exchange_coin.coin.name %></span>
				</div>
				<div class="d-flex justify-content-between mb-3">
					<span>創建時間</span>
					<span><%= @exchange_coin.created_at %></span>
				</div>
			</div>
		</div>
		<div class="nav p-3">
		  <%= link_to "編輯", edit_exchange_coin_path(@exchange_coin), class: "btn btn-warning" %>&nbsp;
		  <%= link_to "返回", exchange_coins_path, class: "btn btn-primary" %>&nbsp;
		  <%= button_to "刪除", @exchange_coin, method: :delete, class: "btn btn-danger", data: { turbo_method: :delete, turbo_confirm: "確認刪除？" } %>
		</div>
	</div>
</div>
