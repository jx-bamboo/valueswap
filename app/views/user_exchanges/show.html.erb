<div class="col-sm-12">
	<div class="card card-pricing">
		<div class="card-body">
			<div class="p-3">
				<div class="d-flex justify-content-between mb-3">
					<span>用户</span>
					<span><%= @user_exchange.user.email %></span>
				</div>
				<div class="d-flex justify-content-between mb-3">
					<span>交易所</span>
					<span class="text-capitalize"><%= @user_exchange.exchange.name %></span>
				</div>
				<div class="d-flex justify-content-between mb-3">
					<span>API Key</span>
					<span><%= mask_string @user_exchange.api_key %></span>
				</div>
				<div class="d-flex justify-content-between mb-3">
					<span>API Secret</span>
					<span><%= mask_string @user_exchange.api_secret %></span>
				</div>
				<div class="d-flex justify-content-between mb-3">
					<span>备注</span>
					<span><%= @user_exchange.memo %></span>
				</div>
			</div>
		</div>
		<div class="nav p-3">
		  <%= link_to "編輯", edit_user_exchange_path(@user_exchange), class: "btn btn-warning" %>&nbsp;
		  <%= link_to "返回", user_exchanges_path, class: "btn btn-primary" %>&nbsp;
		  <%= button_to "刪除", @user_exchange, method: :delete, class: "btn btn-danger", data: { turbo_method: :delete, turbo_confirm: "確認刪除？" } %>
		</div>
	</div>
</div>