<%
=begin%>
 <%= form_with(model: airdrop) do |form| %>
  <% if airdrop.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(airdrop.errors.count, "error") %> prohibited this airdrop from being saved:</h2>

      <ul>
        <% airdrop.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :logo, style: "display: block" %>
    <%= form.text_field :logo %>
  </div>

  <div>
    <%= form.label :intro, style: "display: block" %>
    <%= form.text_field :intro %>
  </div>

  <div>
    <%= form.label :official_web, style: "display: block" %>
    <%= form.text_field :official_web %>
  </div>

  <div>
    <%= form.label :reward, style: "display: block" %>
    <%= form.text_field :reward %>
  </div>

  <div>
    <%= form.label :network, style: "display: block" %>
    <%= form.text_field :network %>
  </div>

  <div>
    <%= form.label :eligibility, style: "display: block" %>
    <%= form.text_field :eligibility %>
  </div>

  <div>
    <%= form.label :begin_time, style: "display: block" %>
    <%= form.datetime_field :begin_time %>
  </div>

  <div>
    <%= form.label :end_time, style: "display: block" %>
    <%= form.datetime_field :end_time %>
  </div>

  <div>
    <%= form.label :status, style: "display: block" %>
    <%= form.number_field :status %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %> 
<%
=end%>

<div class="col-sm-12">
  <div class="card">

    <div class="card-header">
      <div class="fw-bold">添加空投 · Airdrop</div>
    </div>

    <%= form_with(model: airdrop) do |form| %>
      <% if airdrop.errors.any? %>
        <div style="color: red">
          <h2><%= pluralize(airdrop.errors.count, "error") %> prohibited this exchange from being saved:</h2>

          <ul>
            <% airdrop.errors.each do |error| %>
            <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="card-body">
        <div class="row">

          <div class="col-sm-2">
            <div class="form-group mb-3">
              <%= form.label :network, "所属网络", class: "form-label" %>
              <%= form.text_field :network, class: "form-control" %>
            </div>
          </div>

          <div class="col-sm-2">
            <div class="form-group mb-3">
              <%= form.label :name, "项目名称", class: "form-label" %>
              <%= form.text_field :name, class: "form-control" %>
            </div>
          </div>

          <div class="col-sm-2">
            <div class="form-group mb-3">
              <%= form.label :symbol, "代币符号", class: "form-label" %>
              <%= form.text_field :symbol, class: "form-control" %>
            </div>
          </div>

          <div class="col-sm-2">
            <div class="form-group mb-3">
              <%= form.label :tag, "项目标签", class: "form-label" %>
              <%= form.text_field :tag, class: "form-control" %>
            </div>
          </div>

          <div class="col-sm-2">
            <div class="form-group mb-3">
              <%= form.label :total_amount, "代币总量", class: "form-label" %>
              <%= form.text_field :total_amount, class: "form-control" %>
            </div>
          </div>

          <div class="col-sm-2">
            <div class="form-group mb-3">
              <%= form.label :reward_amount, "奖励数量", class: "form-label" %>
              <%= form.text_field :reward_amount, class: "form-control" %>
            </div>
          </div>

          <div class="col-sm-4">
            <div class="form-group mb-3">
              <%= form.label :official_web, "官方网站", class: "form-label" %>
              <%= form.text_field :official_web, class: "form-control", placeholder: "https://www.binance.com" %>
            </div>
          </div>

          <div class="col-sm-2">
            <div class="form-group mb-3">
              <%= form.label :begin_time, "开始时间", class: "form-label" %>
              <%= form.date_field :begin_time, class: "form-control" %>
            </div>
          </div>

          <div class="col-sm-2">
            <div class="form-group mb-3">
              <%= form.label :end_time, "结束时间", class: "form-label" %>
              <%= form.date_field :end_time, class: "form-control" %>
            </div>
          </div>

          <div class="col-sm-4">
            <div class="form-group mb-3">
              <%= form.label :logo, "图标", class: "form-label" %>
              <%= form.file_field :logo, class: "form-control" %>
              <% if @airdrop.logo.present? %>
                <%= image_tag @airdrop.logo, class: "img-fluid" %>
              <% end %>
            </div>
          </div>
          <div class="col-sm-4">
            <div class="form-group mb-3">
              <%= form.label :intro, "项目简介", class: "form-label" %>
              <%= form.text_area :intro, class: "form-control" %>  
              <% if @airdrop.intro.present? %>
                <%= @airdrop.intro %>
              <% end %>
            </div>
          </div>

        </div>
      </div>

      <div class="card-action p-3">
        <%= form.submit "提交", class: "btn btn-success" %>
        <%= link_to "返回", airdrops_path, class: "btn btn-warning" %>
      </div>
    <% end %>
  </div>
</div>