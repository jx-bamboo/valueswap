	.shadow-soft-5 {
	  box-shadow: 0 32px 40px -2px rgba(10,22,70,.04) !important;
	}
	.bg-body {
	  opacity: 1;
	  background-color: rgba(255,255,255,1, 1) !important;
	}
	.h-rem-10 {
	  height: 2.5rem !important;
	}
	.ls-tight {
	  letter-spacing: -.025em !important;
	}
	.text-sm {
	  font-size: .875rem !important;
	}
	.text-primary, .text-primary-hover:hover {
	  color: rgba(rgba(137,87,255,1), 1) !important;
	}
	.form-check-label {
	  font-size: .875rem;
	  font-weight: 500;
	}
</style>

<div class="row g-0 justify-content-center gradient-bottom-right start-purple middle-indigo end-pink">
	<div class="col-md-6 col-lg-5 col-xl-5 position-fixed start-0 top-0 vh-100 overflow-y-hidden d-none d-lg-flex flex-lg-column">
		<div class="p-12 py-xl-10 px-xl-20">
			<a class="d-block" href="/"><%= image_tag "sidebar_logo_1.png", class: "h-rem-10", alt: "Logo" %></a>
			<div class="mt-16">
				<h1 class="ls-tight fw-bolder display-6 text-white mb-5">管理世界頂級資產</h1>
				<!-- <p class="text-white text-opacity-75 pe-xl-24">Create beautiful websites that are supported by rock-solid design principles.</p> -->
			</div>
		</div>
		<div class="mt-auto ps-16 ps-xl-20">
			<%= image_tag "how-works/login-shot.png", class: "img-fluid rounded-top-start-4", alt: "Logo" %>
		</div>
	</div>
	
	<div class="col-12 col-md-12 col-lg-7 offset-lg-5 min-vh-100 overflow-y-auto d-flex flex-column justify-content-center position-relative bg-body rounded-top-start-lg-4 border-start-lg shadow-soft-5">
		<div class="w-md-50 mx-auto px-10 px-md-0 py-10">
			<div class="mb-5">
				<a class="d-inline-block d-lg-none mb-10" href="/">
					<%= image_tag "sidebar_logo_1.png", class: "h-rem-10", alt: "Logo" %>
				</a>
				<h1 class="ls-tight fw-bolder h3 text-dark">登錄您的帳戶</h1>
				<div class="mt-3 text-sm text-muted">
					<span>還沒有帳戶？</span> 
					<a href="/pages/register.html" class="fw-semibold">註冊</a>免費試用.
				</div>
			</div>
			<form>
				<div class="mb-3">
					<label class="form-label text-dark fw-bold" for="email">郵箱</label>
					<input type="email" class="form-control" id="email">
				</div>
				<div class="mb-3">
					<div class="d-flex justify-content-between gap-2 mb-2 align-items-center">
						<label class="form-label mb-0 text-dark fw-bold" for="password">密碼</label> 
						<a href="#" class="text-sm text-muted text-primary-hover text-underline">忘記密碼？</a>
					</div>
					<input type="password" class="form-control" id="password" autocomplete="current-password">
				</div>
				<div class="mb-3">
					<div class="form-check">
						<input class="form-check-input" type="checkbox" name="check_example" id="check_example"> 
						<label class="form-check-label text-dark fw-bold" for="check_example">保持登錄</label>
					</div>
				</div>
				<div><a href="#" class="btn btn-dark w-100">登錄</a></div>
			</form>
			<!-- <div class="py-5 text-center"><span class="text-xs text-uppercase fw-semibold">or</span></div>
			<div class="row g-2">
				<div class="col-sm-6">
					<a href="#" class="btn btn-neutral w-100">
						<span class="icon icon-sm pe-2">
							<img src="../../img/social/github.svg" alt="...">
						</span>Github
					</a>
				</div>
				
				<div class="col-sm-6">
					<a href="#" class="btn btn-neutral w-100">
						<span class="icon icon-sm pe-2">
							<img src="../../img/social/google.svg" alt="...">
						</span>Google
					</a>
				</div>
			</div> -->
		</div>
	</div>
</div>