<div class="mb-5">
	<a class="d-inline-block d-lg-none mb-10" href="/">
		<%= image_tag "logo.svg", class: "h-rem-10", alt: "Logo" %>
	</a>
	<div class="h3 text-dark">登錄您的帳戶</div>
</div>

<% if notice %>
  <p class="btn-primary text-light rounded p-2"><%= notice %></p>
<% elsif alert %>
  <p class="btn-primary text-light rounded p-2"><%= alert %></p>
<% end %>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <div class="mb-3">
    <%= f.label :email, "郵箱", class: "text-dark fw-bold" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :password, "密碼", class: "text-dark fw-bold" %>
    <%= f.password_field :password, autocomplete: "current-password", class: "form-control" %>
  </div>

	<div class="my-2 text-sm text-muted">
		<span>還沒有帳戶？</span> 
		點擊這裡<a href="/users/sign_up" class="fw-semibold">註冊</a>。 
    返回
    <a class="icon-link icon-link-hover" href="/">
      首頁
      <svg xmlns="http://www.w3.org/2000/svg" class="bi" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
      </svg>
    </a>
	</div>

  <%
=begin%>
 <% if devise_mapping.rememberable? %>
    <div class="mb-3">
      <%= f.check_box :remember_me, class: "form-check-input" %>
      <%= f.label :remember_me, "保持登錄", class: "form-check-label text-dark fw-bold" %>
    </div>
  <% end %> 
<%
=end%>

  <div>
    <%= f.submit "登錄", class: "btn btn-dark w-100" %>
  </div>
<% end %>